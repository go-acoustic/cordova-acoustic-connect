{
    "types": "types/index.d.ts",
    "keywords": [
        "ecosystem:cordova",
        "cordova",
        "acoustic",
        "connect",
        "cdp",
        "push"
    ],
    "author": "Acoustic",
    "description": "Cordova plugin for Acoustic Connect (CDP + engagement).",
    "main": "www/AcousticConnect.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/go-acoustic/cordova-acoustic-connect.git"
    },
    "version": "1.0.1",
    "license": "SEE LICENSE IN LICENSE",
    "devDependencies": {
        "eslint": "^9.0.0",
        "plist": "^3.1.0",
        "@eslint/js": "^9.0.0",
        "xml2js": "^0.6.2",
        "jest-junit": "^16.0.0",
        "ts-jest": "^29.1.2",
        "globals": "^15.0.0",
        "@types/jest": "^29.5.12",
        "jest-environment-jsdom": "^29.7.0",
        "typescript": "^5.4.0",
        "jest": "^29.7.0"
    },
    "cordova": {
        "id": "co.acoustic.connect.push",
        "platforms": [
            "ios",
            "android"
        ]
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "name": "cordova-acoustic-connect",
    "files": [
        "www/",
        "types/",
        "scripts/",
        "src/android/*.kt",
        "src/android/*.gradle",
        "src/android/hooks/",
        "src/ios/ConnectNCE/",
        "src/ios/ConnectNSE/",
        "src/ios/*.swift",
        "src/ios/*.rb",
        "src/ios/hooks/",
        "plugin.xml",
        "Package.swift",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "lint": "eslint www types",
        "test": "jest",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test:ruby": "ruby __tests__/smoke_add_ios_push_extensions.rb",
        "pack": "npm pack",
        "test:strict": "tsc --strict --noEmit -p tsconfig.test.json"
    }
}