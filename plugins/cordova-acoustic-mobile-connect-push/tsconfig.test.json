{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true
  },
  "include": [
    "types/**/*.d.ts",
    "__tests__/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "applications",
    "platforms",
    "plugins"
  ]
}
